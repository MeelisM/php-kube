              "name": "POST Create Item",
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "exec": [
                      "const itemName = `Postman inventory item ${Date.now()}`;",
                      "pm.environment.set('INVENTORY_ITEM_NAME', itemName);"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                },
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Create item successful\", function () {",
                      "    pm.response.to.have.status(201);",
                      "    const response = pm.response.json();",
                      "    const expectedName = pm.environment.get('INVENTORY_ITEM_NAME');",
                      "    pm.expect(response).to.be.an('object');",
                      "    pm.expect(response).to.have.property('item');",
                      "    pm.expect(response.item).to.be.an('object');",
                      "    pm.expect(response.item).to.have.property('id');",
                      "    pm.expect(response.item).to.have.property('name');",
                      "    pm.expect(response.item.id).to.be.a('number');",
                      "    pm.expect(response.item.id).to.be.above(0);",
                      "    pm.expect(response.item.name).to.eql(expectedName);",
                      "    pm.environment.set('LAST_CREATED_ITEM_ID', response.item.id);",
                      "});",
                      "",
                      "pm.test(\"Response time is acceptable\", function () {",
                      "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                      "});"
                    ],
